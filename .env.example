# Polymarket EOA Private Key (with or without 0x prefix)
POLYMARKET_PRIVATE_KEY=0x...

# The Wallet Address (Proxy or Safe)
# Used for fetching positions and relaying transactions.
POLY_RELAYER_ADDRESS=0x...

# Wallet Type / Signature Type:
# 0 = EOA (Direct)
# 1 = Proxy (Magic.link / Relay Hub)
# 2 = Safe (Standard Gnosis Safe) - DEFAULT
SIGNATURE_TYPE=2

# Builder HMAC Auth (Gasless Relayer)
# Obtain these from Polymarket Builder settings
BUILDER_KEY=...
BUILDER_SECRET=...
BUILDER_PASSPHRASE=...

# (Optional) Relayer API Key Auth
# POLY_RELAYER_API_KEY=...

# Polygon RPC URL (REQUIRED)
# Used for reading nonces on-chain (to avoid GS026 errors) and direct fallback.
POLYGON_RPC_URL=https://polygon-rpc.com
